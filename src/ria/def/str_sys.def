// ANSI reset commands
X(STR_TERM_HARD_RESET, "\30\33c\33[2J") // Extra \33[2J for minicom.
X(STR_TERM_SOFT_RESET, "\30\33[?47l\33[?33l\33[0m\33(B\33[?7h\33[?25h\33[3g")

