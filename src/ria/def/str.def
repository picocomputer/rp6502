/* ADD A LANGUAGE - no C knowledge needed, and you never touch a .c/.h file.
 *
 * 1. Copy def/str_en.def to a new def/str_<lang>.def.
 * 2. Add #include "def/str_<lang>.def" line below.
 * 3. Edit the new file:
 *      - Set XSUFFIX to a unique ALL_CAPS tag (e.g. FR) and edit the XBEGIN
 *        line: the code users type in SET LOC (e.g. "FR"), the language's own
 *        name (e.g. "Francais"), and its default OEM code-page number.
 *      - Translate ONLY the text inside the quotes. Keep every STR_... name
 *        exactly once - don't rename, drop, or duplicate one.
 *      - For the code page on the XBEGIN line, pick the OEM page that covers
 *        your language's characters (HELP SET CP lists the supported pages);
 *        e.g. English uses 437, Polish uses 852.
 * 4. Build and test with SET LOC <code>.
 */

#include "def/str_en.def"
#include "def/str_pl.def"
