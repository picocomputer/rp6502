// clang-format off
#include "ria/def/def.h"
#define XSUFFIX US_INTL
XBEGIN("US-INTL", "United States - International")

// XKEY(keycode, unmodified, shift, altGr, shift+altGr, use_caps_lock)
XKEY(0x04, 'a',  'A',  0x00e1, 0x00c1,  true) // a A á Á
XKEY(0x05, 'b',  'B',  0,      0,       true)
XKEY(0x06, 'c',  'C',  0x00a9, 0x00a2,  true) // c C © ¢
XKEY(0x07, 'd',  'D',  0x00f0, 0x00d0,  true) // d D ð Ð
XKEY(0x08, 'e',  'E',  0x00e9, 0x00c9,  true) // e E é É
XKEY(0x09, 'f',  'F',  0,      0,       true)
XKEY(0x0a, 'g',  'G',  0,      0,       true)
XKEY(0x0b, 'h',  'H',  0,      0,       true)
XKEY(0x0c, 'i',  'I',  0x00ed, 0x00cd,  true) // i I í Í
XKEY(0x0d, 'j',  'J',  0,      0,       true)
XKEY(0x0e, 'k',  'K',  0,      0,       true)
XKEY(0x0f, 'l',  'L',  0x00f8, 0x00d3,  true) // l L ø Ó
XKEY(0x10, 'm',  'M',  0,      0,       true)
XKEY(0x11, 'n',  'N',  0x00f1, 0x00d1,  true) // n N ñ Ñ
XKEY(0x12, 'o',  'O',  0x00f3, 0x00d3,  true) // o O ó Ó
XKEY(0x13, 'p',  'P',  0x00f6, 0x00d6,  true) // p P ö Ö
XKEY(0x14, 'q',  'Q',  0x00e4, 0x00c4,  true) // q Q ä Ä
XKEY(0x15, 'r',  'R',  0,      0,       true)
XKEY(0x16, 's',  'S',  0x00df, 0x00a7,  true) // s S ß §
XKEY(0x17, 't',  'T',  0x00fe, 0x00de,  true) // t T þ Þ
XKEY(0x18, 'u',  'U',  0x00fa, 0x00da,  true) // u U ú Ú
XKEY(0x19, 'v',  'V',  0,      0,       true)
XKEY(0x1a, 'w',  'W',  0x00e5, 0x00c5,  true) // w W å Å
XKEY(0x1b, 'x',  'X',  0,      0,       true)
XKEY(0x1c, 'y',  'Y',  0x00fc, 0x00dc,  true) // y Y ü Ü
XKEY(0x1d, 'z',  'Z',  0x00e6, 0x00c6,  true) // z Z æ Æ
XKEY(0x1e, '1',  '!',  0x00a1, 0x00b9, false) // 1 ! ¡ ¹
XKEY(0x1f, '2',  '@',  0x00b2, 0,      false) // 2 @ ²
XKEY(0x20, '3',  '#',  0x00b3, 0,      false) // 3 # ³
XKEY(0x21, '4',  '$',  0x00a4, 0x00a3, false) // 4 $ ¤ £
XKEY(0x22, '5',  '%',  0x20ac, 0,      false) // 5 % €
XKEY(0x23, '6',  '^',  0x00bc, 0,      false) // 6 ^ ¼
XKEY(0x24, '7',  '&',  0x00bd, 0,      false) // 7 & ½
XKEY(0x25, '8',  '*',  0x00be, 0,      false) // 8 * ¾
XKEY(0x26, '9',  '(',  0x2018, 0,      false) // 9 ( ‘
XKEY(0x27, '0',  ')',  0x2019, 0,      false) // 0 ) ’
XKEY(0x28, '\r', '\r', 0,      0,      false) // Enter
XKEY(0x29, 0x001b, 0x001b, 0,  0,      false) // Esc
XKEY(0x2a, 0x007f, 0x007f, 0,  0,      false) // Backspace
XKEY(0x2b, '\t', '\t', 0,      0,      false) // Tab
XKEY(0x2c, ' ',  ' ',  0,      0,      false) // Space
XKEY(0x2d, '-',  '_',  0x00a5, 0,      false) // - _ ¥
XKEY(0x2e, '=',  '+',  0x00d7, 0x00f7, false) // = + × ÷
XKEY(0x2f, '[',  '{',  0x00ab, 0,      false) // [ { «
XKEY(0x30, ']',  '}',  0x00bb, 0,      false) // ] } »
XKEY(0x31, '\\', '|',  0x00ac, 0x00a6, false) // \ | ¬ ¦
XKEY(0x33, ';',  ':',  0x00b6, 0x00b0, false) // ; : ¶ °
XKEY(0x34, '\'', '\"', 0x00b4, 0x00a8, false) // ' " ´ ¨
XKEY(0x35, '`',  '~',  0,      0,      false)
XKEY(0x36, ',',  '<',  0x00e7, 0,      false) // , < ç
XKEY(0x37, '.',  '>',  0,      0,      false)
XKEY(0x38, '/',  '?',  0x00bf, 0,      false) // / ? ¿
// Keypad
XKEY(0x54, '/',  '/',  0,      0,      false)
XKEY(0x55, '*',  '*',  0,      0,      false)
XKEY(0x56, '-',  '-',  0,      0,      false)
XKEY(0x57, '+',  '+',  0,      0,      false)
XKEY(0x58, '\r', '\r', 0,      0,      false)
XKEY(0x59, '1',  0,    0,      0,      false)
XKEY(0x5a, '2',  0,    0,      0,      false)
XKEY(0x5b, '3',  0,    0,      0,      false)
XKEY(0x5c, '4',  0,    0,      0,      false)
XKEY(0x5d, '5',  0,    0,      0,      false)
XKEY(0x5e, '6',  0,    0,      0,      false)
XKEY(0x5f, '7',  0,    0,      0,      false)
XKEY(0x60, '8',  0,    0,      0,      false)
XKEY(0x61, '9',  0,    0,      0,      false)
XKEY(0x62, '0',  0,    0,      0,      false)
XKEY(0x63, '.',  0,    0,      0,      false)
XKEY(0x64, '\\', '|',  0,      0,      false)
XKEY(0x67, '=',  '=',  0,      0,      false)

// Dead keys: XDEAD(dead_key, base_key, result)
XDEAD('`',  'a', 0x00e0) // à
XDEAD('\'', 'a', 0x00e1) // á
XDEAD('^',  'a', 0x00e2) // â
XDEAD('~',  'a', 0x00e3) // ã
XDEAD('\"', 'a', 0x00e4) // ä
