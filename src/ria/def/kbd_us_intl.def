XDEAD('\'', 'i', 0x00ed) // í
XDEAD('^',  'i', 0x00ee) // î
XDEAD('\"', 'i', 0x00ef) // ï
XDEAD('`',  'I', 0x00cc) // Ì
XDEAD('\'', 'I', 0x00cd) // Í
XDEAD('^',  'I', 0x00ce) // Î
XDEAD('\"', 'I', 0x00cf) // Ï
XDEAD('`',  'o', 0x00f2) // ò
XDEAD('\'', 'o', 0x00f3) // ó
XDEAD('^',  'o', 0x00f4) // ô
XDEAD('~',  'o', 0x00f5) // õ
XDEAD('\"', 'o', 0x00f6) // ö
XDEAD('`',  'O', 0x00d2) // Ò
XDEAD('\'', 'O', 0x00d3) // Ó
XDEAD('^',  'O', 0x00d4) // Ô
XDEAD('~',  'O', 0x00d5) // Õ
XDEAD('\"', 'O', 0x00d6) // Ö
XDEAD('`',  'u', 0x00f9) // ù
XDEAD('\'', 'u', 0x00fa) // ú
XDEAD('^',  'u', 0x00fb) // û
XDEAD('\"', 'u', 0x00fc) // ü
XDEAD('`',  'U', 0x00d9) // Ù
XDEAD('\'', 'U', 0x00da) // Ú
XDEAD('^',  'U', 0x00db) // Û
XDEAD('\"', 'U', 0x00dc) // Ü
XDEAD('`',  'y', 0x1ef3) // ỳ
XDEAD('\'', 'y', 0x00fd) // ý
XDEAD('^',  'y', 0x0177) // ŷ
XDEAD('~',  'y', 0x1ef9) // ỹ
XDEAD('\"', 'y', 0x00ff) // ÿ
XDEAD('`',  'Y', 0x1ef2) // Ỳ
XDEAD('\'', 'Y', 0x00dd) // Ý
XDEAD('^',  'Y', 0x0176) // Ŷ
XDEAD('~',  'Y', 0x1ef8) // Ỹ
XDEAD('\"', 'Y', 0x0178) // Ÿ
XDEAD('\'', 'c', 0x00e7) // ç
XDEAD('\'', 'C', 0x00c7) // Ç
