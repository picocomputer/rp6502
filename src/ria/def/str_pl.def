X(STR_HELP_HELP,
  "Komendy:\n"
  "HELP (komenda|rom)  - \aTa pomoc lub rozszerzona pomoc komendy albo rom.\n"
  "HELP ABOUT|SYSTEM   - \aABOUT zawiera autor√≥w. SYSTEM opisuje uŇľycie.\n"
  "STATUS              - \aPokaŇľ status systemu i podŇāńÖczonych urzńÖdzeŇĄ.\n"
  "SET (atr) (wart)    - \aZmieŇĄ lub pokaŇľ ustawienia.\n"
  "DIR (kat|napńôd)     - \aWypisz zawartoŇõńá katalogu.\n"
  "LS (kat)            - \aZmieŇĄ lub pokaŇľ bieŇľńÖcy katalog.\n"
  "(MSC)0:             - \aMSC0:-MSC9: ZmieŇĄ bieŇľńÖce urzńÖdzenie pamińôci.\n"
  "LOAD plik           - \aWczytaj plik ROM. Uruchom, jeŇõli ma wektor resetu.\n"
  "INFO plik           - \aPokaŇľ tekst pomocy z pliku ROM, jeŇõli istnieje.\n"
  "INSTALL plik (rom)  - \aZainstaluj plik ROM w RIA.\n"
  "rom                 - \aWczytaj i uruchom zainstalowany ROM.\n"
  "REMOVE rom          - \aUsuŇĄ ROM z RIA.\n"
  "REBOOT              - \aZrestartuj RIA. Wczyta wybrany startowy ROM.\n"
  "RESET               - \aUruchom 6502 od bieŇľńÖcego wektora resetu ($FFFC).\n"
  "FLASH plik          - \aFlashuj plik UF2, aby zaktualizowańá RIA lub VGA.\n"
  "MKDIR kat           - \aUtw√≥rz nowy katalog.\n"
  "UNLINK plik|kat     - \aUsuŇĄ plik lub pusty katalog.\n"
  "COPY Ňļr√≥dŇāo cel     - \aSkopiuj plik.\n"
  "MOVE Ňļr√≥dŇāo cel     - \aPrzenieŇõ albo zmieŇĄ nazwńô pliku lub katalogu.\n"
  "UPLOAD plik         - \aZapisz plik. Potem nastńôpujńÖ bloki binarne.\n"
  "BINARY adr dŇā crc   - \aZapisz pamińôńá. Potem nastńôpujńÖ dane binarne.\n"
  "0000 (00 00 ...)    - \aCzytaj lub zapisuj pamińôńá.\n")

X(STR_HELP_SET,
  "Ustawienia:\n"
  "HELP SET atr       - \aPokaŇľ informacje o ustawieniu.\n"
  "SET PHI2 (kHz)     - \aSprawdŇļ lub ustaw prńôdkoŇõńá PHI2 (zegar 6502).\n"
  "SET BOOT (rom|-)   - \aWybierz ROM startowy po zimnym starcie. \"-\" oznacza brak.\n"
  "SET TZ (tz)        - \aSprawdŇļ lub ustaw strefńô czasowńÖ.\n"
  "SET KB (ukŇāady)    - \aSprawdŇļ lub ustaw ukŇāady klawiatury.\n"
  "SET CP (cp)        - \aSprawdŇļ lub ustaw stronńô kodowńÖ.\n"
  "SET VGA (0|1|2)    - \aSprawdŇļ lub ustaw typ obrazu dla wyjŇõcia VGA.\n"
  "SET NFC (0|1|2|86) - \aWyŇāńÖcz lub wŇāńÖcz czytnik NFC. 2 skanuje PN532.\n")

X(STR_HELP_SET_W,
  "SET RF (0|1)       - \aWyŇāńÖcz lub wŇāńÖcz radio.\n"
  "SET RFCC (cc|-)    - \aUstaw kod kraju dla RF. \"-\" oznacza caŇāy Ňõwiat.\n"
  "SET SSID (ssid|-)  - \aUstaw SSID WiFi. \"-\" oznacza brak.\n"
  "SET PASS (hasŇāo|-) - \aUstaw hasŇāo WiFi. \"-\" oznacza brak.\n"
  "SET PORT (port)    - \aUstaw port TCP zdalnej konsoli telnet.\n"
  "SET KEY (klucz|-)  - \aUstaw klucz dostńôpu zdalnej konsoli. \"-\" oznacza brak.\n"
  "SET BLE (0|1|2|86) - \aWyŇāńÖcz lub wŇāńÖcz Bluetooth LE. 2 wŇāńÖcza parowanie.\n")

X(STR_HELP_SYSTEM,
  "Picocomputer nie uŇľywa tradycyjnego r√≥wnolegŇāego ROM-u, takiego jak 27C64\n"
  "lub podobny. Zamiast tego ten monitor przygotowuje RAM 6502 oprogramowaniem,\n"
  "kt√≥re normalnie znajdowaŇāoby sińô w koŇõci ROM. 6502 jest teraz w stanie resetu;\n"
  "linia RESB jest niska. To, co widzisz, pochodzi z RP6502-RIA. MoŇľesz wr√≥cińá\n"
  "do tego monitora w dowolnym momencie, naciskajńÖc CTRL-ALT-DEL albo wysyŇāajńÖc\n"
  "break do portu szeregowego. PoniewaŇľ te sygnaŇāy obsŇāuguje RP6502-RIA, zawsze\n"
  "zatrzymajńÖ 6502, nawet po awarii. Ten monitor moŇľe wykonywańá skrypty przydatne\n"
  "podczas tworzenia oprogramowania. Udostńôpnia teŇľ komendy interaktywne, na\n"
  "przykŇāad wpisanie adresu szesnastkowego, aby zobaczyńá odpowiednińÖ wartoŇõńá RAM:\n"
  "]0200\n"
  "0200  DA DA DA DA DA DA DA DA  |........|\n"
  "64KB pamińôci rozszerzonej (XRAM) jest mapowane od $10000 do $1FFFF.\n"
  "Zakres pamińôci podaj ze znakiem \"-\":\n"
  "]10000-100FF\n"
  "MoŇľesz teŇľ zapisywańá pamińôńá. Na przykŇāad, aby zapisańá wektor RESET 6502:\n"
  "]FFFC 00 02\n"
  "Dozwolony jest format Intel HEX:\n"
  "]:02FFFC00000201\n"
  "Rńôczna manipulacja pamińôcińÖ jest przydatna do prostego debugowania,\n"
  "ale prawdziwa siŇāa tkwi w innych komendach opisanych w tym systemie pomocy.\n"
  "MiŇāej zabawy!\n")

X(STR_HELP_DIR,
  "LS (takŇľe pod aliasem DIR) i CD sŇāuŇľńÖ do poruszania sińô po urzńÖdzeniach pamińôci\n"
  "pamińôci masowej USB. MoŇľesz przeŇāńÖczyńá sińô na inne urzńÖdzenie USB przez\n"
  "0: do 7:. UŇľyj komendy STATUS, aby uzyskańá listńô zamontowanych napńôd√≥w.\n")

X(STR_HELP_MKDIR,
  "MKDIR sŇāuŇľy do tworzenia nowych katalog√≥w. UŇľyj UNLINK, aby usuwańá puste katalogi.\n")

X(STR_HELP_LOAD,
  "LOAD i INFO odczytujńÖ pliki ROM z napńôdu USB. Plik ROM zawiera zar√≥wno\n"
  "informacje ASCII dla uŇľytkownika, jak i informacje binarne dla systemu.\n"
  "Wiersze mogńÖ koŇĄczyńá sińô LF albo CRLF. Pierwszy wiersz musi zawierańá wyŇāńÖcznie:\n"
  "#!RP6502\n"
  "Po nim nastńôpujńÖ wiersze HELP/INFO zaczynajńÖce sińô od # i spacji:\n"
  "# Fajna Gra V0.0 autor Super Dev\n"
  "Po wierszach informacyjnych dane binarne poprzedzajńÖ wiersze ASCII z liczbami\n"
  "szesnastkowymi lub dziesińôtnymi okreŇõlajńÖcymi adres, dŇāugoŇõńá i CRC-32.\n"
  "$C000 1024 0x0C0FFEE0\n"
  "Po tym nastńôpujńÖ dane binarne. Maksymalna dŇāugoŇõńá to 1024 bajty, wińôc powtarzaj\n"
  "wedŇāug potrzeby. CRC-32 jest obliczane tńÖ samńÖ metodńÖ co zip.\n"
  "JeŇõli plik ROM zawiera dane dla wektora RESET $FFFC-$FFFD, 6502 zostanie\n"
  "zresetowany (uruchomiony) natychmiast po wczytaniu.\n")

X(STR_HELP_INSTALL,
  "INSTALL i REMOVE zarzńÖdzajńÖ ROM-ami zainstalowanymi w pamińôci flash RP6502 RIA.\n"
  "Aby moŇľna byŇāo je zainstalowańá, pliki ROM muszńÖ zawierańá wektor resetu.\n"
  "Lista zainstalowanych ROM-√≥w jest pokazywana na podstawowym ekranie HELP.\n"
  "Po zainstalowaniu ROM-y stajńÖ sińô integralnńÖ czńôŇõcińÖ systemu i moŇľna je wczytańá\n"
  "rńôcznie, uŇľywajńÖc po prostu samej ich nazwy jak kaŇľdej innej komendy.\n"
  "Nazwa ROM nie moŇľe kolidowańá z ŇľadnńÖ komendńÖ systemowńÖ,\n"
  "musi zaczynańá sińô od litery i moŇľe zawierańá najwyŇľej 16 liter i cyfr ASCII.\n"
  "JeŇõli plik ma rozszerzenie, musi to byńá \".rp6502\";\n"
  "zostanie ono usunińôte podczas instalacji.\n")

X(STR_HELP_REBOOT,
  "REBOOT zrestartuje RIA. DziaŇāa tak samo jak naciŇõnińôcie przycisku RESET\n"
  "podŇāńÖczonego do pinu RIA RUN albo odŇāńÖczenie zasilania.\n")

X(STR_HELP_RESET,
  "RESET uruchomi 6502, ustawiajńÖc RESB w stan wysoki. Ten monitor zostanie "
  "wstrzymany, aŇľ 6502 zatrzyma sińô przez UART break, CTRL-ALT-DEL albo exit().\n")

X(STR_HELP_FLASH,
  "FLASH odczytuje plik UF2 z napńôdu USB i flashuje go do RIA albo VGA.\n"
  "JeŇõli flashowanie sińô nie powiedzie, odzyskaj przez USB standardowńÖ metodńÖ\n"
  "BOOTSEL (przytrzymaj BOOTSEL podczas podŇāńÖczania USB do komputera,\n"
  "a potem skopiuj plik).\n")

X(STR_HELP_UPLOAD,
  "UPLOAD sŇāuŇľy do wysŇāania pliku z innego systemu do lokalnego systemu plik√≥w.\n"
  "Plik moŇľe mieńá dowolny typ i dowolnńÖ nazwńô oraz nadpisze istniejńÖcy plik\n"
  "o tej samej nazwie. Na przykŇāad moŇľesz wysŇāańá plik ROM razem z innymi\n"
  "plikami zawierajńÖcymi grafikńô lub dane poziom√≥w gry.\n"
  "Potem moŇľesz uruchomińá grńô przy pomocy LOAD rom i jńÖ przetestowańá.\n"
  "PrzesyŇāanie zaczyna sińô od nazwy pliku.\n"
  "]UPLOAD plik.bin\n"
  "System odpowie znakiem zachńôty \"}\" albo komunikatem bŇāńôdu zaczynajńÖcym sińô od \"?\".\n"
  "KaŇľdy bŇāńÖd przerwie przesyŇāanie i wr√≥cisz do monitora.\n"
  "Nie ma ponawiania,poniewaŇľ UPLOAD nie jest przeznaczone dla poŇāńÖczeŇĄ stratnych.\n"
  "KaŇľdy blok podaj z dŇāugoŇõcińÖ do 1024 bajt√≥w oraz CRC-32, kt√≥re moŇľesz obliczyńá\n"
  "dowolnńÖ bibliotekńÖ zip.\n"
  "}$400 $0C0FFEE0\n"
  "WyŇõlij dane binarne, a otrzymasz kolejny znak zachńôty \"}\" albo bŇāńÖd \"?\".\n"
  "Transfer koŇĄczy komenda END albo pusty wiersz do wyboru.\n"
  "}END\n"
  "Po sukcesie wr√≥cisz do znaku zachńôty \"]\", a po niepowodzeniu do bŇāńôdu \"?\".\n")

X(STR_HELP_UNLINK,
  "UNLINK (takŇľe pod aliasem RM) usuwa plik lub katalog.\n"
