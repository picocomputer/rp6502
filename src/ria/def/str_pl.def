X(STR_HELP_HELP,
  "Komendy:\n"
  "HELP (komenda|rom)  - \aTa pomoc lub rozszerzona pomoc komendy albo rom.\n"
  "HELP ABOUT|SYSTEM   - \aABOUT zawiera autorów. SYSTEM opisuje użycie.\n"
  "STATUS              - \aPokaż status systemu i podłączonych urządzeń.\n"
  "SET (atr) (wart)    - \aZmień lub pokaż ustawienia.\n"
  "DIR (kat|napęd)     - \aWypisz zawartość katalogu.\n"
  "LS (kat)            - \aZmień lub pokaż bieżący katalog.\n"
  "(MSC)0:             - \aMSC0:-MSC9: Zmień bieżące urządzenie pamięci.\n"
  "LOAD plik           - \aWczytaj plik ROM. Uruchom, jeśli ma wektor resetu.\n"
  "INFO plik           - \aPokaż tekst pomocy z pliku ROM, jeśli istnieje.\n"
  "INSTALL plik (rom)  - \aZainstaluj plik ROM w RIA.\n"
  "rom                 - \aWczytaj i uruchom zainstalowany ROM.\n"
  "REMOVE rom          - \aUsuń ROM z RIA.\n"
  "REBOOT              - \aZrestartuj RIA. Wczyta wybrany startowy ROM.\n"
  "RESET               - \aUruchom 6502 od bieżącego wektora resetu ($FFFC).\n"
  "FLASH plik          - \aFlashuj plik UF2, aby zaktualizować RIA lub VGA.\n"
  "MKDIR kat           - \aUtwórz nowy katalog.\n"
  "UNLINK plik|kat     - \aUsuń plik lub pusty katalog.\n"
  "COPY źródło cel     - \aSkopiuj plik.\n"
  "MOVE źródło cel     - \aPrzenieś albo zmień nazwę pliku lub katalogu.\n"
  "DISK pod dys ...    - \aInfo, etykieta, format, kasowanie i weryfikacja dysku.\n"
  "UPLOAD plik         - \aZapisz plik. Potem następują bloki binarne.\n"
  "BINARY adr dł crc   - \aZapisz pamięć. Potem następują dane binarne.\n"
  "0000 (00 00 ...)    - \aCzytaj lub zapisuj pamięć.\n")

X(STR_HELP_SET,
  "Ustawienia:\n"
  "HELP SET atr       - \aPokaż informacje o ustawieniu.\n"
  "SET PHI2 (kHz)     - \aSprawdź lub ustaw prędkość PHI2 (zegar 6502).\n"
  "SET BOOT (rom|-)   - \aWybierz ROM startowy po zimnym starcie. \"-\" oznacza brak.\n"
  "SET TZ (tz)        - \aSprawdź lub ustaw strefę czasową.\n"
  "SET KB (układy)    - \aSprawdź lub ustaw układy klawiatury.\n"
  "SET CP (cp)        - \aSprawdź lub ustaw stronę kodową.\n"
  "SET VGA (0|1|2)    - \aSprawdź lub ustaw typ obrazu dla wyjścia VGA.\n"
  "SET NFC (0|1|2|86) - \aWyłącz lub włącz czytnik NFC. 2 skanuje PN532.\n")

X(STR_HELP_SET_W,
  "SET RF (0|1)       - \aWyłącz lub włącz radio.\n"
  "SET RFCC (cc|-)    - \aUstaw kod kraju dla RF. \"-\" oznacza cały świat.\n"
  "SET SSID (ssid|-)  - \aUstaw SSID WiFi. \"-\" oznacza brak.\n"
  "SET PASS (hasło|-) - \aUstaw hasło WiFi. \"-\" oznacza brak.\n"
  "SET PORT (port)    - \aUstaw port TCP zdalnej konsoli telnet.\n"
  "SET KEY (klucz|-)  - \aUstaw klucz dostępu zdalnej konsoli. \"-\" oznacza brak.\n"
  "SET BLE (0|1|2|86) - \aWyłącz lub włącz Bluetooth LE. 2 włącza parowanie.\n")

X(STR_HELP_SYSTEM,
  "Picocomputer nie używa tradycyjnego równoległego ROM-u, takiego jak 27C64\n"
  "lub podobny. Zamiast tego ten monitor przygotowuje RAM 6502 oprogramowaniem,\n"
  "które normalnie znajdowałoby się w kości ROM. 6502 jest teraz w stanie resetu;\n"
  "linia RESB jest niska. To, co widzisz, pochodzi z RP6502-RIA. Możesz wrócić\n"
  "do tego monitora w dowolnym momencie, naciskając CTRL-ALT-DEL albo wysyłając\n"
  "break do portu szeregowego. Ponieważ te sygnały obsługuje RP6502-RIA, zawsze\n"
  "zatrzymają 6502, nawet po awarii. Ten monitor może wykonywać skrypty przydatne\n"
  "podczas tworzenia oprogramowania. Udostępnia też komendy interaktywne, na\n"
  "przykład wpisanie adresu szesnastkowego, aby zobaczyć odpowiednią wartość RAM:\n"
  "]0200\n"
  "0200  DA DA DA DA DA DA DA DA  |........|\n"
  "64KB pamięci rozszerzonej (XRAM) jest mapowane od $10000 do $1FFFF.\n"
  "Zakres pamięci podaj ze znakiem \"-\":\n"
  "]10000-100FF\n"
  "Możesz też zapisywać pamięć. Na przykład, aby zapisać wektor RESET 6502:\n"
  "]FFFC 00 02\n"
  "Dozwolony jest format Intel HEX:\n"
  "]:02FFFC00000201\n"
  "Ręczna manipulacja pamięcią jest przydatna do prostego debugowania,\n"
  "ale prawdziwa siła tkwi w innych komendach opisanych w tym systemie pomocy.\n"
  "Miłej zabawy!\n")

X(STR_HELP_DIR,
  "LS (także pod aliasem DIR) i CD służą do poruszania się po urządzeniach pamięci\n"
  "pamięci masowej USB. Możesz przełączyć się na inne urządzenie USB przez\n"
  "0: do 7:. Użyj komendy STATUS, aby uzyskać listę zamontowanych napędów.\n")

X(STR_HELP_MKDIR,
  "MKDIR służy do tworzenia nowych katalogów. Użyj UNLINK, aby usuwać puste katalogi.\n")

X(STR_HELP_LOAD,
  "LOAD i INFO odczytują pliki ROM z napędu USB. Plik ROM zawiera zarówno\n"
  "informacje ASCII dla użytkownika, jak i informacje binarne dla systemu.\n"
  "Wiersze mogą kończyć się LF albo CRLF. Pierwszy wiersz musi zawierać wyłącznie:\n"
  "#!RP6502\n"
  "Po nim następują wiersze HELP/INFO zaczynające się od # i spacji:\n"
  "# Fajna Gra V0.0 autor Super Dev\n"
  "Po wierszach informacyjnych dane binarne poprzedzają wiersze ASCII z liczbami\n"
  "szesnastkowymi lub dziesiętnymi określającymi adres, długość i CRC-32.\n"
  "$C000 1024 0x0C0FFEE0\n"
  "Po tym następują dane binarne. Maksymalna długość to 1024 bajty, więc powtarzaj\n"
  "według potrzeby. CRC-32 jest obliczane tą samą metodą co zip.\n"
  "Jeśli plik ROM zawiera dane dla wektora RESET $FFFC-$FFFD, 6502 zostanie\n"
  "zresetowany (uruchomiony) natychmiast po wczytaniu.\n")

X(STR_HELP_INSTALL,
  "INSTALL i REMOVE zarządzają ROM-ami zainstalowanymi w pamięci flash RP6502 RIA.\n"
  "Aby można było je zainstalować, pliki ROM muszą zawierać wektor resetu.\n"
  "Lista zainstalowanych ROM-ów jest pokazywana na podstawowym ekranie HELP.\n"
  "Po zainstalowaniu ROM-y stają się integralną częścią systemu i można je wczytać\n"
  "ręcznie, używając po prostu samej ich nazwy jak każdej innej komendy.\n"
  "Nazwa ROM nie może kolidować z żadną komendą systemową,\n"
  "musi zaczynać się od litery i może zawierać najwyżej 16 liter i cyfr ASCII.\n"
  "Jeśli plik ma rozszerzenie, musi to być \".rp6502\";\n"
  "zostanie ono usunięte podczas instalacji.\n")

X(STR_HELP_REBOOT,
  "REBOOT zrestartuje RIA. Działa tak samo jak naciśnięcie przycisku RESET\n"
  "podłączonego do pinu RIA RUN albo odłączenie zasilania.\n")

X(STR_HELP_RESET,
  "RESET uruchomi 6502, ustawiając RESB w stan wysoki. Ten monitor zostanie "
  "wstrzymany, aż 6502 zatrzyma się przez UART break, CTRL-ALT-DEL albo exit().\n")

X(STR_HELP_FLASH,
  "FLASH odczytuje plik UF2 z napędu USB i flashuje go do RIA albo VGA.\n"
  "Jeśli flashowanie się nie powiedzie, odzyskaj przez USB standardową metodą\n"
  "BOOTSEL (przytrzymaj BOOTSEL podczas podłączania USB do komputera,\n"
  "a potem skopiuj plik).\n")

X(STR_HELP_UPLOAD,
  "UPLOAD służy do wysłania pliku z innego systemu do lokalnego systemu plików.\n"
  "Plik może mieć dowolny typ i dowolną nazwę oraz nadpisze istniejący plik\n"
  "o tej samej nazwie. Na przykład możesz wysłać plik ROM razem z innymi\n"
  "plikami zawierającymi grafikę lub dane poziomów gry.\n"
  "Potem możesz uruchomić grę przy pomocy LOAD rom i ją przetestować.\n"
  "Przesyłanie zaczyna się od nazwy pliku.\n"
  "]UPLOAD plik.bin\n"
  "System odpowie znakiem zachęty \"}\" albo komunikatem błędu zaczynającym się od \"?\".\n"
  "Każdy błąd przerwie przesyłanie i wrócisz do monitora.\n"
  "Nie ma ponawiania,ponieważ UPLOAD nie jest przeznaczone dla połączeń stratnych.\n"
  "Każdy blok podaj z długością do 1024 bajtów oraz CRC-32, które możesz obliczyć\n"
  "dowolną biblioteką zip.\n"
  "}$400 $0C0FFEE0\n"
  "Wyślij dane binarne, a otrzymasz kolejny znak zachęty \"}\" albo błąd \"?\".\n"
  "Transfer kończy komenda END albo pusty wiersz do wyboru.\n"
  "}END\n"
  "Po sukcesie wrócisz do znaku zachęty \"]\", a po niepowodzeniu do błędu \"?\".\n")

X(STR_HELP_UNLINK,
  "UNLINK (także pod aliasem RM) usuwa plik lub katalog.\n"
  "Jest przeznaczone do skryptów na innym systemie podłączonym do monitora.\n"
  "Na przykład możesz chcieć usunąć dane zapisu w ramach testów automatycznych.\n")

X(STR_HELP_COPY,
  "COPY powiela plik katalog. Cel może być nową nazwą pliku albo katalogiem.\n")

X(STR_HELP_MOVE,
  "MOVE zmienia nazwę pliku lub katalogu albo przenosi go na tym samym napędzie.\n"
  "Cel może być nową nazwą albo katalogiem.\n")

X(STR_HELP_BINARY,
  "BINARY to najszybszy sposób przesłania kodu lub danych z systemu budowania\n"
  "do RAM 6502. Użyj komendy \"BINARY adres długość CRC\" z maksymalną długością\n"
  "1024 bajtów i CRC-32 obliczonym biblioteką zip. Potem wyślij dane binarne.\n"
  "Po taransmisji zakończonej sukcesem wrócisz do znaku zachęty \"]\",\n"
  "a po niepowodzeniu do błędu \"?\".\n")

X(STR_HELP_STATUS,
  "STATUS pokaże status całego sprzętu w RIA i podłączonego do RIA.\n")

X(STR_HELP_SET_PHI2,
  "PHI2 to prędkość zegara 6502 w kHz. Prawidłowy zakres to " STR_PHI2_MIN_MAX ",\n"
  "ale nie wszystkie częstotliwości są dostępne. W takim przypadku następna wyższa\n"
  "częstotliwość zostanie automatycznie obliczona i wybrana. Ustawienie jest\n"
  "zapisywane w pamięci flash RIA.\n")

X(STR_HELP_SET_BOOT,
  "BOOT wybiera zainstalowany ROM, który ma być automatycznie wczytany\n"
  "i uruchomiony po włączeniu zasilania albo restarcie systemu. Na przykład możesz\n"
  "chcieć, aby system od razu startował do BASIC-a albo CLI systemu operacyjnego.\n"
  "Użycie argumentu \"-\" spowoduje start systemu do monitora, którego teraz używasz.\n"
  "Ustawienie jest zapisywane w pamięci flash RIA.\n")

X(STR_HELP_SET_TZ,
  "Możesz ustawić strefę czasową z poniższej tabeli, podając samo miasto,\n"
  "np. \"SET TZ LOS_ANGELES\", albo pełną nazwę \"SET TZ AMERICA/LOS_ANGELES\".\n"
  "Dla lokalizacji spoza tabeli można użyć SET TZ z łańcuchem POSIX TZ,\n"
  "na przykład \"SET TZ PST8PDT,M3.2.0/2,M11.1.0/2\". Najłatwiej uzyskać łańcuch\n"
  "POSIX TZ, pytając AI: \"posix tz dla {twoja lokalizacja}\".\n")

X(STR_HELP_SET_LOC,
  "SET LOC wybiera język interfejsu. Gdy SET CP jest automatyczne, ustawia też\n"
  "stronę kodową, np. SET LOC PL\n")

X(STR_HELP_SET_KB,
  "SET KB wybiera układy klawiatury. np. SET KB US DE PL-PROG\n"
  "Naciśnij Super+Spacja, aby przełączać układy.\n")

X(STR_HELP_SET_CP,
  "SET CP wybiera systemową stronę kodową OEM. SET CP 0 to tryb automatyczny\n"
  "(domyślny): strona kodowa podąża za językiem ustawionym przez SET LOC.\n"
  "Każda inna wartość to stałe nadpisanie. Obsługiwane są: 437, 720, 737, 771,\n"
  "775, 850, 852, 855, 857, 860, 861, 862, 863, 864, 865, 866, 869.\n")

X(STR_HELP_SET_VGA,
  "SET VGA wybiera typ wyświetlacza dla wyjścia VGA. Wszystkie rozdzielczości\n"
  "obrazu są obsługiwane przez wszystkie typy wyświetlacza. Typ wyświetlacza\n"
  "służy do zachowania kwadratowych pikseli i minimalizacji pasów.\n"
  "Pamiętaj, że 1280x1024 ma proporcje 5:4, więc grafika 4:3 będzie miała\n"
  "niewielkie marginesy, ale terminal będzie powiększony o 2 wiersze.\n"
  "  0 - \a640x480, dla wyświetlaczy 4:3\n"
  "  1 - \a640x480 i 1280x720, dla wyświetlaczy 16:9\n"
  "  2 - \a1280x1024, dla wyświetlaczy 5:4 SXGA\n")

X(STR_HELP_SET_NFC,
  "SET NFC (0|1|2|86) wyłącza|włącza|skanuje|czyści zapisane urządzenie NFC.\n")

X(STR_HELP_SET_RF,
  "SET RF (0|1) wyłącza|włącza wszystkie urządzenia radiowe.\n")

X(STR_HELP_SET_RFCC,
  "Ustaw to, aby CYW43 mógł używać najlepszych częstotliwości radiowych\n"
  "dla Twojego kraju. Użycie \"-\" wyczyści kod kraju i przywróci ustawienie światowe.\n")

X(STR_HELP_SET_SSID,
  "To jest identyfikator SSID twojej sieci WiFi. Ustawienie \"-\" wyłączy WiFi.\n")

X(STR_HELP_SET_PASS,
  "SET PASS {hasło} \austawia hasło Twojej sieci WiFi.\n"
  "SET PASS -       \ausuwa zapisane hasło.\n")

X(STR_HELP_SET_BLE,
  "SET BLE (0|1) \awyłącza|włącza Bluetooth LE.\n"
  "SET BLE 2     \aprzechodzi w tryb parowania, który pozostanie aktywny do sukcesu.\n"
  "SET BLE 86    \ausuwa i rozłącza wszystkie sparowane urządzenia.\n")

X(STR_HELP_SET_PORT,
  "SET PORT {nr portu} \austawia port TCP zdalnego dostępu do konsoli przez telnet. "
  "Standardowy port telnet to 23.\n"
  "SET PORT 0          \awyłącza konsolę telnet.\n"
  "Aby włączyć dostęp do konsoli telnet, muszą być ustawione zarówno PORT\n"
  "jak i KEY (patrz \"help KEY\").\n")

X(STR_HELP_SET_KEY,
  "SET KEY {klucz} \austawia klucz dostępu do zdalnej konsoli telnet.\n"
  "SET KEY -       \ausuwa klucz.\n"
  "Aby włączyć dostęp do konsoli telnet, muszą być ustawione zarówno KEY\n"
  " jak i PORT (patrz \"help KEY\").\n")

X(STR_HELP_DISK,
  "Dysk:\n"
  "HELP DISK pod        - \aPokaż pomoc dla podpolecenia dysku.\n"
  "DISK INFO dys        - \aPokaż urządzenie, format i zajętość.\n"
  "DISK LABEL dys (et)  - \aPokaż lub ustaw etykietę woluminu.\n"
  "DISK FORMAT dys ..   - \aUtwórz system plików. Patrz HELP DISK FORMAT.\n"
  "DISK ERASE dys       - \aNadpisz wszystkie dane zerami. Patrz HELP DISK ERASE.\n"
  "DISK VERIFY dys      - \aOdczytaj wszystkie sektory i zgłoś uszkodzone.\n")

X(STR_HELP_DISK_INFO,
  "DISK INFO dysk\n"
  "Pokazuje urządzenie, format na dysku (układ, system plików, rozmiar klastra, "
  "etykietę) oraz zajętość woluminu. Dyski nazywają się MSCn: lub n:.\n")

X(STR_HELP_DISK_FORMAT,
  "DISK FORMAT dysk [/fat|/exfat] [/sfd|/mbr|/gpt] [/512|/4k...] [/quick|/full] [etykieta]\n"
  "Tworzy system plików na dysku o nazwie MSCn: lub n:. /fat (domyślnie) jest "
  "najbardziej zgodny; /exfat nadaje się do dużych dysków. Układ: /sfd, /mbr lub "
  "/gpt; domyślnie SFD dla dyskietek, MBR dla flash. /512 i wyższe potęgi dwójki "
  "ustawiają rozmiar "
  "klastra (domyślnie wg pojemności). /quick (domyślnie) zapisuje tylko system "
  "plików; /full dodaje formatowanie niskopoziomowe (tylko dyskietki). "
  "Wyświetlany jest podgląd; wpisz YES, aby potwierdzić.\n")

X(STR_HELP_DISK_FORMAT_BASIC,
  "DISK FORMAT dysk [/sfd|/mbr] [/512|/4k...] [/quick|/full] [etykieta]\n"
  "Tworzy system plików FAT na dysku o nazwie MSCn: lub n:. Układ: /sfd lub /mbr; "
  "domyślnie SFD dla dyskietek, MBR dla flash. /512 i wyższe potęgi dwójki "
  "ustawiają rozmiar klastra "
  "(domyślnie wg pojemności). /quick (domyślnie) zapisuje tylko system plików; "
  "/full dodaje formatowanie niskopoziomowe (tylko dyskietki). Wyświetlany jest "
  "podgląd; wpisz YES, aby potwierdzić.\n")

X(STR_HELP_DISK_ERASE,
  "DISK ERASE dysk\n"
  "Usuwa wszystkie dane z dysku o nazwie MSCn: lub n:, nadpisując każdy sektor "
  "zerami, co pokonuje programy do odzyskiwania plików, ale dane mogą pozostać "
  "w przemapowanych komórkach flash. Wpisz YES, aby potwierdzić.\n")

X(STR_HELP_DISK_VERIFY,
  "DISK VERIFY dysk\n"
  "Odczytuje wszystkie sektory dysku o nazwie MSCn: lub n: i zgłasza te, których "
  "nie udało się odczytać. Tylko do odczytu. Naciśnij Ctrl-C, aby przerwać.\n")

X(STR_HELP_DISK_LABEL,
  "DISK LABEL dysk [etykieta]\n"
  "Bez etykiety pokazuje etykietę woluminu dysku o nazwie MSCn: lub n:. Z "
  "etykietą ustawia ją i wypisuje starą oraz nową nazwę. Podaj puste \"\", aby "
  "wyczyścić etykietę.\n")

XEND()
#undef XSUFFIX
