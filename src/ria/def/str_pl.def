X(STR_HELP_STATUS,
  "STATUS pokaŇľe status caŇāego sprzńôtu w RIA i podŇāńÖczonego do RIA.\n")

X(STR_HELP_SET_PHI2,
  "PHI2 to prńôdkoŇõńá zegara 6502 w kHz. PrawidŇāowy zakres to " STR_PHI2_MIN_MAX ",\n"
