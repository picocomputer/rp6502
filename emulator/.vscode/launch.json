{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug rp6502-emu (hello.rp6502)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/rp6502-emu",
            "args": [
                "${workspaceFolder}/tests/roms/hello.rp6502"
            ],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "externalConsole": false,
            "MIMode": "gdb",
            "preLaunchTask": "Build",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
