#
# Build the WebAssembly demo and deploy it to GitHub Pages.
#
# Inactive until you switch Pages on: repository Settings -> Pages -> Build and
# deployment -> Source: "GitHub Actions". Until then this workflow does nothing.
#
# It builds the emulator with Emscripten into build/web/ (the full deployable
# web root, exactly what tools/build_web.sh produces) and publishes that folder.
name: Deploy web demo

on:
  push:
    branches: [main]
  workflow_dispatch:

# Least privilege for the deploy: read the repo, write Pages, mint the OIDC
# token actions/deploy-pages uses.
permissions:
  contents: read
  pages: write
  id-token: write

# One deploy at a time; let an in-progress run finish rather than cancelling.
concurrency:
  group: pages
  cancel-in-progress: false

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          # Need src/rp6502, src/sokol, src/chips (the WASM target) plus
          # src/emsdk (the pinned Emscripten SDK installer). NOT recursive:
          # that would drag in tinyusb's deep MCU-HAL tree (see README).
          submodules: true

      - name: Install build tools
        run: sudo apt-get update && sudo apt-get install -y cmake ninja-build

      # Cache the toolchain tools/build_web.sh fetches INTO the submodule, keyed
      # on the pinned version so a version bump invalidates it.
      - name: Cache Emscripten toolchain
        uses: actions/cache@v4
        with:
          path: |
            src/emsdk/upstream
            src/emsdk/node
            src/emsdk/.emscripten
          key: emsdk-${{ runner.os }}-${{ hashFiles('tools/emscripten-version.txt') }}

      - name: Build web demo
        # Installs the pinned Emscripten into src/emsdk (unless restored from
        # cache), then builds build/web/ via the self-contained wasm preset.
        run: tools/build_web.sh

      - name: Upload Pages artifact
        uses: actions/upload-pages-artifact@v3
        with:
          path: build/web

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
